# Line endings — LF for source, binary for media
*.html         text eol=lf
*.css          text eol=lf
*.js           text eol=lf
*.md           text eol=lf
*.jpg          binary
*.JPG          binary
*.jpeg         binary
*.JPEG         binary
*.png          binary
*.PNG          binary
*.webp         binary
*.gif          binary
*.mp4          binary
*.MP4          binary
*.mov          binary
*.MOV          binary
*.webm         binary
